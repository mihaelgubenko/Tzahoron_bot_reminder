{
  "name": "liora-landing",
  "version": "1.0.0",
  "description": "Landing page for Liora kindergarten extended care service",
  "main": "server.js",
  "bin": "server.js",
  "pkg": {
    "assets": [
      "index.html",
      "login.html",
      "admin.html",
      "styles.css",
      "robots.txt",
      "sitemap.xml",
      "images/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ]
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "build:exe": "pkg . --targets node18-win-x64 --output dist/Liora-Server.exe"
  },
  "keywords": [
    "landing",
    "kindergarten",
    "liora"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-session": "^1.18.2",
    "nodemailer": "^6.9.7"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
